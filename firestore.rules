rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    //  Helper Functions
    // ──────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return request.auth != null
        && request.auth.uid == 'QZ62mytbllhPt7wWkv6gKtmz31l1';
    }

    function validString(field, maxLen) {
      return request.resource.data[field] is string
        && request.resource.data[field].size() <= maxLen;
    }

    // ──────────────────────────────────────────────
    //  Users
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['displayName'])
        && validString('displayName', 32);

      allow update: if isAuthenticated()
        && request.auth.uid == userId;

      allow delete: if isOwner();
    }

    // ──────────────────────────────────────────────
    //  Presence
    //  Authenticated users write their own UID doc.
    //  Anonymous visitors write a session-ID doc (anon-*).
    // ──────────────────────────────────────────────
    match /presence/{userId} {
      allow read: if true;

      // Authenticated: own UID only
      allow write: if isAuthenticated()
        && request.auth.uid == userId;

      // Anonymous: session ID must start with "anon-" and be short
      allow write: if !isAuthenticated()
        && userId.matches('anon-.{8}')
        && request.resource.data.keys().hasAll(['uid', 'name', 'ts']);

      allow delete: if true;
    }

    // ──────────────────────────────────────────────
    //  Catch-all deny
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
